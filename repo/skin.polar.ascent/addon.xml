<addon id="skin.polar.ascent" name="Polar Ascent" provider-name="flightrisk77" version="1.2.0">
    <requires>
        <import addon="xbmc.gui" version="5.17.0" />
        <import addon="resource.images.polar.ascent" version="1.0.0"/>
        <import addon="script.skinvariables" version="2.1.28" />
        <import addon="script.texturemaker" version="0.2.11" />
        <import addon="plugin.video.themoviedb.helper" version="6.14.3" />
        <import addon="resource.images.weathericons.white" version="0.0.1" />
        <import addon="resource.images.studios.coloured" version="0.0.1" />
        <import addon="resource.font.robotocjksc" version="0.0.3" />
    </requires>
    <extension debugging="false" defaultthemename="Textures.xbt" effectslowdown="1" point="xbmc.gui.skin">
        <res aspect="16:9" default="true" folder="1080i" width="1920" height="1080" />
        <res aspect="3:2" default="false" folder="1080i" width="1620" height="1080" />
        <res aspect="4:3" default="false" folder="1080i" width="1440" height="1080" />
        <res aspect="16:10" default="false" folder="1080i" width="1728" height="1080" />
        <res aspect="17:9" default="false" folder="1080i" width="2040" height="1080" />
        <res aspect="21:9" default="false" folder="1080i" width="2520" height="1080" />
        <res aspect="19.5:9" default="false" folder="1080i" width="2340" height="1080" />
        <res aspect="18:9" default="false" folder="1080i" width="2160" height="1080" />
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">A minimal row based skin</summary>
        <description lang="en_GB">Polar Ascent is a sleek, customizable skin featuring a minimal row-based layout with 7 fully configurable hub slots, dynamic background switching, and seamless widget integration. Built for a clean, modern Kodi experience.</description>        
        <platform>all</platform>
        <license>Creative Commons Attribution Non-Commercial Share-Alike 4.0</license>
        <forum />
        <source />
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
