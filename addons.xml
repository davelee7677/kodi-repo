      <description>TMDbHelper Context Menu</description>
    </extension>
    <extension point="xbmc.addon.metadata">
      <summary lang="en">TMDbHelper Context Menu</summary>
      <description lang="en">Context menu integration for TMDb Helper.</description>
      <platform>all</platform>
